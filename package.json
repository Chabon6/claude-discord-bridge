{
  "name": "claude-discord-bridge",
  "version": "1.0.0",
  "description": "Production-grade Discord <-> Claude Code bridge with streaming, sessions, and addon system",
  "main": "daemon/core/index.js",
  "type": "module",
  "bin": {
    "claude-discord-bridge": "daemon/bin/claude-discord-bridge.js"
  },
  "scripts": {
    "start": "node daemon/bin/claude-discord-bridge.js",
    "dev": "node --watch daemon/bin/claude-discord-bridge.js",
    "register": "node scripts/register-commands.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "discord",
    "claude",
    "claude-code",
    "bot",
    "bridge",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
