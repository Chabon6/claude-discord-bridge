# ============================================================
# claude-discord-bridge — Environment Variables
# ============================================================

# -- Required --------------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-application-id

# -- Core (Optional) ------------------------------------------
# DISCORD_GUILD_ID=              # Guild to restrict (default: all guilds)
# DISCORD_CHANNEL_ID=            # Channel to monitor (default: all channels bot is in)
# CLAUDE_CLI_PATH=claude          # Path to Claude CLI binary
# CLAUDE_CWD=                     # Working directory for Claude execution (default: $HOME)
# LOCALE=en                       # Message language: en | zh-TW
# REQUIRE_MENTION=true            # Require @mention in channel messages (threads always OK)
# MENTION_EXEMPT_CHANNELS=        # Comma-separated channel IDs exempt from mention gating
# INIT_TIMEOUT_SEC=300            # Two-phase init timeout (seconds)
# EXEC_TIMEOUT_SEC=3600           # Execution timeout (seconds)
# NOTIFY_CHANNEL_ID=              # Channel for startup/shutdown notifications (default: none)
# PERMISSION_MODE=full-auto       # Default: full-auto | auto | acceptEdits | plan | dontAsk
# THREAD_TTL_MS=43200000          # Thread session TTL (default: 12h)
# DEDUP_TTL_MS=60000              # Dedup cache TTL (default: 1min)
# LOG_RETENTION_DAYS=7            # NDJSON log retention
# LOG_DIR=logs                    # Log output directory

# -- DM Policy -------------------------------------------------
# DM_ENABLED=true                 # Allow DM conversations (default: true)
# DM_ALLOWLIST=                   # Comma-separated user IDs (empty = allow all if DM_ENABLED)

# -- Wiki Ingest Addon (Optional) ------------------------------
# WIKI_INGEST_CHANNEL_ID=        # Channel where URLs trigger knowledge-wiki ingest
# WIKI_DIR=                       # Knowledge wiki directory (default: ~/knowledge-wiki)
# WIKI_CLAUDE_PATH=               # Claude CLI path for wiki (default: CLAUDE_CLI_PATH)

# -- Auto-Intel Addon (Optional) -------------------------------
# AUTO_INTEL_CHANNEL_ID=         # Channel for auto-intel summaries
# AUTO_INTEL_INTERVAL_MS=3600000 # Research interval (default: 1 hour)
# AUTO_INTEL_MAX_5H_PCT=80       # 5h rate limit % threshold (from ECC statusline cache)
# AUTO_INTEL_MAX_7D_PCT=80       # 7d rate limit % threshold (from ECC statusline cache)
# AUTO_INTEL_MAX_DAILY_COST=20.00 # Fallback: max daily spend (USD, via ccusage)
# AUTO_INTEL_MAX_7DAY_COST=150.00 # Fallback: max 7-day spend (USD, via ccusage)
# AUTO_INTEL_STARTUP_DELAY_MS=60000 # Delay before first run after startup (ms)

# -- Auto-Intel: User Profile (用於 prompt 個人化) ----------
# AUTO_INTEL_USER_NAME=          # 使用者姓名或暱稱（會出現在 LLM prompt 中）
# AUTO_INTEL_USER_PROFILE=       # 一句話描述使用者背景（如「會計師、Python 工程師、關注金融科技」）
# AUTO_INTEL_USER_RELEVANCE=     # 對使用者「相關」的判準（如「職涯發展、技能提升、投資決策」）

# -- Auto-Intel: Podcast 逐字稿偵測 (Optional) -----------------
# NOTION_KEY_STATEMENTDOG=       # Notion API key for Podcast 逐字稿 database access
# AUTO_INTEL_PODCAST_DB_ID=      # Notion Database ID for "Podcast 逐字稿 & memo"

# -- Emoji Reactions (Optional) --------------------------------
# ACK_EMOJI=eyes                  # Unicode emoji name for acknowledgement
# TYPING_EMOJI=hourglass          # Unicode emoji name for processing
# DONE_EMOJI=white_check_mark     # Unicode emoji name for completion
# ERROR_EMOJI=x                   # Unicode emoji name for error
