# ============================================================
# claude-discord-bridge — Environment Variables
# ============================================================

# -- Required --------------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-application-id

# -- Core (Optional) ------------------------------------------
# DISCORD_GUILD_ID=              # Guild to restrict (default: all guilds)
# DISCORD_CHANNEL_ID=            # Channel to monitor (default: all channels bot is in)
# CLAUDE_CLI_PATH=claude          # Path to Claude CLI binary
# CLAUDE_CWD=                     # Working directory for Claude execution (default: $HOME)
# LOCALE=en                       # Message language: en | zh-TW
# REQUIRE_MENTION=true            # Require @mention in channel messages (threads always OK)
# INIT_TIMEOUT_SEC=300            # Two-phase init timeout (seconds)
# EXEC_TIMEOUT_SEC=3600           # Execution timeout (seconds)
# PERMISSION_MODE=full-auto       # Default: full-auto | auto | acceptEdits | plan | dontAsk
# THREAD_TTL_MS=43200000          # Thread session TTL (default: 12h)
# DEDUP_TTL_MS=60000              # Dedup cache TTL (default: 1min)
# LOG_RETENTION_DAYS=7            # NDJSON log retention
# LOG_DIR=logs                    # Log output directory

# -- DM Policy -------------------------------------------------
# DM_ENABLED=true                 # Allow DM conversations (default: true)
# DM_ALLOWLIST=                   # Comma-separated user IDs (empty = allow all if DM_ENABLED)

# -- Emoji Reactions (Optional) --------------------------------
# ACK_EMOJI=eyes                  # Unicode emoji name for acknowledgement
# TYPING_EMOJI=hourglass          # Unicode emoji name for processing
# DONE_EMOJI=white_check_mark     # Unicode emoji name for completion
# ERROR_EMOJI=x                   # Unicode emoji name for error
